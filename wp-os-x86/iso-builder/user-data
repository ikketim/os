#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  storage:
    layout:
      name: lvm
      match:
        size: largest
  identity:
    hostname: @@OS_HOSTNAME@@
    username: @@OS_USERNAME@@
    password: "@@OS_PASSWORD_HASH@@"
    realname: "WhiteoutProject OS"
  ssh:
    install-server: true
    allow-pw: true
  packages:
    - python3
    - python3-full
    - python3-venv
    - python3-pip
    - python3-flask
    - wget
    - curl
    - git
    - feh
    - x11vnc
    - xvfb
    - net-tools
    - jq
    - ca-certificates
    - p7zip-full
  late-commands:
    - cp /cdrom/wp-os/wp-os-provision.sh /target/usr/local/bin/wp-os-provision.sh
    - chmod +x /target/usr/local/bin/wp-os-provision.sh
    - cp /cdrom/wp-os/wp-os-switch-bot.sh /target/usr/local/bin/wp-os-switch-bot.sh
    - chmod +x /target/usr/local/bin/wp-os-switch-bot.sh
    - mkdir -p /target/@@WEBSERVER_DIR@@
    - cp /cdrom/wp-os/app.py /target/@@WEBSERVER_DIR@@/app.py
    - cp /cdrom/wp-os/wp-os-firstboot.service /target/etc/systemd/system/wp-os-firstboot.service
    - curtin in-target --target=/target -- systemctl enable wp-os-firstboot.service
  shutdown: reboot
